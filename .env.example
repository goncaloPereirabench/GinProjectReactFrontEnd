# Browser-facing API base URL. Leave empty for local dev so Vite proxies /v1 and /health.
# Production example: VITE_API_BASE_URL=https://ca-api-gin-grocery-dev-t5n05b.kindbeach-885bc456.northeurope.azurecontainerapps.io
VITE_API_BASE_URL=

# Local development only. Used by vite.config.ts when VITE_API_BASE_URL is empty.
VITE_API_PROXY_TARGET=http://localhost:8080
